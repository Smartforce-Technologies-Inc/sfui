    "predeploy": "npm run build-storybook",
    "deploy": "gh-pages -d storybook-static",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook",
    "copy-styles": "cpx \"src/**/*.scss\" dist/Styles"
  },
